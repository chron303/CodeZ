  "topic": "Hashing",
  "difficulty": "Easy",
  "description": "Given an integer array nums, return true if any value appears at least twice in the array, and return false if every element is distinct.",
  "url": "https://leetcode.com/problems/contains-duplicate/",
  "tags": ["array", "hash-map", "sorting"],
  "examples": [
    {
      "input": "nums = [1,2,3,1]",
      "output": "true"
    },
    {
      "input": "nums = [1,2,3,4]",
      "output": "false"
    }
  ],
  "testCases": [
    { "label": "Has duplicate",    "input": "[1,2,3,1]",           "stdinLines": "4\n1 2 3 1",           "expected": "true",  "hidden": false },
    { "label": "All distinct",     "input": "[1,2,3,4]",           "stdinLines": "4\n1 2 3 4",           "expected": "false", "hidden": false },
    { "label": "Triple duplicate", "input": "[1,1,1,3,3,4,3,2,4,2]", "stdinLines": "10\n1 1 1 3 3 4 3 2 4 2", "expected": "true", "hidden": false },
    { "label": "Single element",   "input": "[1]",                 "stdinLines": "1\n1",                 "expected": "false", "hidden": true }
